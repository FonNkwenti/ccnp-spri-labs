<mxGraphModel background="#1a1a2e">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ═══════════════════════════════════════════════════════════
         ZONE — IS-IS L2 + SR-MPLS Domain (AS 65100)
         ═══════════════════════════════════════════════════════════ -->
    <mxCell id="zone_sr_core" value="AS 65100  |  IS-IS L2 + SR-MPLS  |  SRGB 16000-23999"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#37474F;strokeWidth=2;fillColor=#1a2226;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="120" y="120" width="600" height="460" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         TITLE
         ═══════════════════════════════════════════════════════════ -->
    <mxCell id="title" value="&lt;font style=&quot;font-size:16px;&quot; color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Lab 00: SR-MPLS Foundations, SRGB, and Prefix SIDs&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="80" y="20" width="780" height="35" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         DEVICE ICONS — 4 IOS-XRv 9000 routers in a square + diagonal
         R1 top-left, R2 top-right, R3 bottom-right, R4 bottom-left
         ═══════════════════════════════════════════════════════════ -->

    <!-- R1 — top-left; neighbors: R2 (right), R4 (down), R3 (diagonal) → label left -->
    <mxCell id="R1" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R1&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;SR Core&lt;br&gt;Lo0: 10.0.0.1/32&lt;br&gt;SID: 16001&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="220" y="200" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R2 — top-right; neighbors: R1 (left), R3 (down) → label right -->
    <mxCell id="R2" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R2&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;SR Core&lt;br&gt;Lo0: 10.0.0.2/32&lt;br&gt;SID: 16002&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=left;labelPosition=right;"
      vertex="1" parent="1">
      <mxGeometry x="560" y="200" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R3 — bottom-right; neighbors: R2 (up), R4 (left), R1 (diagonal) → label right -->
    <mxCell id="R3" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R3&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;SR Core&lt;br&gt;Lo0: 10.0.0.3/32&lt;br&gt;SID: 16003&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=left;labelPosition=right;"
      vertex="1" parent="1">
      <mxGeometry x="560" y="480" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R4 — bottom-left; neighbors: R3 (right), R1 (up) → label left -->
    <mxCell id="R4" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R4&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;SR Core&lt;br&gt;Lo0: 10.0.0.4/32&lt;br&gt;SID: 16004&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="220" y="480" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         PHYSICAL LINKS — white strokes, IS-IS L2 + SR-MPLS
         ═══════════════════════════════════════════════════════════ -->

    <!-- L1: R1 Gi0/0/0/0 ↔ R2 Gi0/0/0/0  10.1.12.0/24 -->
    <mxCell id="link_L1" value="Gi0/0/0/0 - Gi0/0/0/0&#10;10.1.12.0/24 (L1)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="R1" target="R2">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L2: R2 Gi0/0/0/1 ↔ R3 Gi0/0/0/0  10.1.23.0/24 -->
    <mxCell id="link_L2" value="Gi0/0/0/1 - Gi0/0/0/0&#10;10.1.23.0/24 (L2)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="R2" target="R3">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L3: R3 Gi0/0/0/1 ↔ R4 Gi0/0/0/0  10.1.34.0/24 -->
    <mxCell id="link_L3" value="Gi0/0/0/1 - Gi0/0/0/0&#10;10.1.34.0/24 (L3)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="R3" target="R4">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L4: R1 Gi0/0/0/1 ↔ R4 Gi0/0/0/1  10.1.14.0/24 -->
    <mxCell id="link_L4" value="Gi0/0/0/1 - Gi0/0/0/1&#10;10.1.14.0/24 (L4)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="R1" target="R4">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L5: R1 Gi0/0/0/2 ↔ R3 Gi0/0/0/2  10.1.13.0/24 (diagonal — TI-LFA anchor in lab-01) -->
    <mxCell id="link_L5" value="Gi0/0/0/2 - Gi0/0/0/2&#10;10.1.13.0/24 (L5 diagonal)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="R1" target="R3">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         IP LAST-OCTET LABELS
         Device positions: R1(220,200) R2(560,200) R3(560,480) R4(220,480)
         Icon = 60x60; right edge = x+60, bottom edge = y+60, center = x+30
         ═══════════════════════════════════════════════════════════ -->

    <!-- L1 octets (top horizontal): R1.1 (right of R1) | R2.2 (left of R2) -->
    <mxCell id="oct_L1_R1" value=".1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="295" y="218" as="geometry" />
