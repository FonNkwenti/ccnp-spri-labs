    <!-- ═══════════════════════════════════════════════════════════
         LEGEND
         ═══════════════════════════════════════════════════════════ -->
    <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;&lt;br&gt;━━━  Physical link (IS-IS L2 + SR-MPLS)&lt;br&gt;[grey zone] AS 65100 SR-MPLS core&lt;br&gt;&lt;br&gt;&lt;b&gt;Prefix SIDs&lt;/b&gt;&lt;br&gt;R1 → 16001  |  R2 → 16002&lt;br&gt;R3 → 16003  |  R4 → 16004&lt;br&gt;&lt;br&gt;SRGB: 16000-23999  |  SRLB: 15000-15999&lt;br&gt;IS-IS Level-2-only, metric-style wide" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;arcSize=3;" vertex="1" parent="1">
      <mxGeometry x="760" y="200" width="290" height="160" as="geometry" />
