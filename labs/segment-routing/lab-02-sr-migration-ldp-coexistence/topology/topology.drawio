                <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;&lt;br&gt;━━━  Physical Link (IS-IS L2 + SR-MPLS + LDP)&lt;br&gt;L1–L4: Ring links&lt;br&gt;L5: Diagonal (TI-LFA PQ-node anchor)&lt;br&gt;&lt;br&gt;Protocol: IS-IS Level 2&lt;br&gt;Data plane: SR-MPLS + LDP (parallel)&lt;br&gt;FRR: TI-LFA + BFD 50ms&lt;br&gt;SRGB: 16000–23999&lt;br&gt;Prefix SIDs: 16001–16004&lt;br&gt;Mapping Server (R1): 192.0.2.0/24&lt;br&gt;  → SID index 50, label 16050, range 100&lt;br&gt;sr-prefer: SR wins over LDP for mapped prefixes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;arcSize=3;" parent="1" vertex="1">
