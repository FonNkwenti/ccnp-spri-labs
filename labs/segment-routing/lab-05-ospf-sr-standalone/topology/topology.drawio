<mxGraphModel background="#1a1a2e">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ═══════════════════════════════════════════════════════════
         ZONE — OSPF Area 0 (Backbone) — drawn FIRST so it renders behind devices
         Encloses R1(390,180), R2(610,180), R3(390,460), R4(170,460)
         with ≥30px padding on all sides
         ═══════════════════════════════════════════════════════════ -->
    <mxCell id="zone_area0" value="Area 0 (Backbone)&#10;OSPFv2 Process 1 | SRGB 16000-23999"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#1565C0;strokeWidth=2;fillColor=#1a3a5c;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="120" y="130" width="600" height="420" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         TITLE
         ═══════════════════════════════════════════════════════════ -->
    <mxCell id="title" value="&lt;font style=&quot;font-size:16px;&quot; color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Lab 05: OSPF Segment Routing Extensions (Standalone)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="80" y="20" width="840" height="35" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         DEVICE ICONS — IOS-XRv 9000 routers
         Layout: R1 top-center, R2 top-right, R3 bottom-center, R4 bottom-left
         R1(390,180)  R2(610,180)
         R4(170,460)  R3(390,460)
         ═══════════════════════════════════════════════════════════ -->

    <!-- R1 — top-center; connects right (L1→R2), down (L5→R3), diag-left (L4→R4)
         No connections go above or far left → label left -->
    <mxCell id="R1" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R1&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;SP Edge / SR Ingress&lt;br&gt;Lo0: 10.0.0.1/32&lt;br&gt;SID: 16001&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="390" y="180" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R2 — top-right; connects left (L1→R1), diag-down-left (L2→R3)
         No connections go right → label right -->
    <mxCell id="R2" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R2&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;SP Core&lt;br&gt;Lo0: 10.0.0.2/32&lt;br&gt;SID: 16002&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=left;labelPosition=right;"
      vertex="1" parent="1">
      <mxGeometry x="610" y="180" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R3 — bottom-center; connects up (L5→R1), diag-up-right (L2→R2), left (L3→R4)
         Connections approach from left, right, and above → label right (fallback) -->
    <mxCell id="R3" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R3&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;SP Edge / SR Egress&lt;br&gt;Lo0: 10.0.0.3/32&lt;br&gt;SID: 16003&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=left;labelPosition=right;"
      vertex="1" parent="1">
      <mxGeometry x="390" y="460" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R4 — bottom-left; connects right (L3→R3), diag-up-right (L4→R1)
         No connections go left → label left -->
    <mxCell id="R4" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R4&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;SP Core&lt;br&gt;Lo0: 10.0.0.4/32&lt;br&gt;SID: 16004&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="170" y="460" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         PHYSICAL LINKS — white strokes, OSPFv2 area 0 + SR-MPLS
         ═══════════════════════════════════════════════════════════ -->

    <!-- L1: R1 Gi0/0/0/0 ↔ R2 Gi0/0/0/0  10.1.12.0/24  (top horizontal) -->
    <mxCell id="link_L1" value="Gi0/0/0/0 - Gi0/0/0/0&#10;10.1.12.0/24 (L1)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="R1" target="R2">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L2: R2 Gi0/0/0/1 ↔ R3 Gi0/0/0/0  10.1.23.0/24  (right diagonal R2→R3) -->
    <mxCell id="link_L2" value="Gi0/0/0/1 - Gi0/0/0/0&#10;10.1.23.0/24 (L2)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="R2" target="R3">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L3: R3 Gi0/0/0/1 ↔ R4 Gi0/0/0/0  10.1.34.0/24  (bottom horizontal) -->
    <mxCell id="link_L3" value="Gi0/0/0/1 - Gi0/0/0/0&#10;10.1.34.0/24 (L3)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="R3" target="R4">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L4: R1 Gi0/0/0/1 ↔ R4 Gi0/0/0/1  10.1.14.0/24  (left diagonal R1→R4) -->
    <mxCell id="link_L4" value="Gi0/0/0/1 - Gi0/0/0/1&#10;10.1.14.0/24 (L4)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="R1" target="R4">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L5: R1 Gi0/0/0/2 ↔ R3 Gi0/0/0/2  10.1.13.0/24  (center vertical diagonal) -->
    <mxCell id="link_L5" value="Gi0/0/0/2 - Gi0/0/0/2&#10;10.1.13.0/24 (L5 diagonal)" style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=9;align=center;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="R1" target="R3">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         IP LAST-OCTET LABELS
         Device positions (top-left corner of 60x60 icon):
           R1(390,180)  R2(610,180)  R3(390,460)  R4(170,460)
         Icon center: x+30, y+30
         ═══════════════════════════════════════════════════════════ -->

    <!-- L1 (top horizontal R1↔R2): R1.1 right-of-R1 icon | R2.2 left-of-R2 icon -->
    <mxCell id="oct_L1_R1" value=".1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="465" y="198" as="geometry" />
    </mxCell>
    <mxCell id="oct_L1_R2" value=".2" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="592" y="198" as="geometry" />
    </mxCell>

    <!-- L2 (R2 bottom ↔ R3 right): R2.2 below R2 | R3.3 upper-right of R3 -->
    <mxCell id="oct_L2_R2" value=".2" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="645" y="260" as="geometry" />
    </mxCell>
    <mxCell id="oct_L2_R3" value=".3" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="464" y="442" as="geometry" />
    </mxCell>

    <!-- L3 (bottom horizontal R3↔R4): R3.3 left-of-R3 icon | R4.4 right-of-R4 icon -->
    <mxCell id="oct_L3_R3" value=".3" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="372" y="478" as="geometry" />
    </mxCell>
    <mxCell id="oct_L3_R4" value=".4" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="248" y="478" as="geometry" />
    </mxCell>

    <!-- L4 (left diagonal R1↔R4): R1.1 lower-left of R1 | R4.4 upper-right of R4 -->
    <mxCell id="oct_L4_R1" value=".1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="366" y="262" as="geometry" />
    </mxCell>
    <mxCell id="oct_L4_R4" value=".4" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="214" y="442" as="geometry" />
    </mxCell>

    <!-- L5 (center vertical R1↔R3): R1.1 lower-center of R1 | R3.3 upper-center of R3 -->
    <mxCell id="oct_L5_R1" value=".1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="435" y="262" as="geometry" />
    </mxCell>
    <mxCell id="oct_L5_R3" value=".3" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;" vertex="1" connectable="0" parent="1">
      <mxGeometry x="435" y="440" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════
         LEGEND — bottom-right, black fill, white text
         ═══════════════════════════════════════════════════════════ -->
    <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;&lt;br&gt;━━━  Physical link (OSPF area 0 + SR-MPLS)&lt;br&gt;[blue zone] Area 0 Backbone&lt;br&gt;&lt;br&gt;&lt;b&gt;Prefix SIDs&lt;/b&gt;&lt;br&gt;R1 → 16001  |  R2 → 16002&lt;br&gt;R3 → 16003  |  R4 → 16004&lt;br&gt;&lt;br&gt;SRGB: 16000-23999&lt;br&gt;OSPF Process ID: 1 | Area 0 only&lt;br&gt;Standalone (no IS-IS, no LDP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;arcSize=3;" vertex="1" parent="1">
      <mxGeometry x="760" y="280" width="230" height="185" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
