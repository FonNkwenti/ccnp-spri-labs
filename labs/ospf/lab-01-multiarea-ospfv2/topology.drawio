<?xml version="1.0" encoding="UTF-8"?>
<mxGraphModel background="#1a1a2e">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- TITLE                                                       -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <mxCell id="title" value="&lt;font style=&quot;font-size:16px;&quot; color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Lab 01: Multiarea OSPFv2 and LSA Propagation&lt;/b&gt;&lt;/font&gt;"
      style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="100" y="20" width="700" height="35" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- ZONE SHAPES — drawn FIRST so they render behind devices    -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Area 1 (Normal) — green: encloses R1, R2, link L1 -->
    <mxCell id="area1_shape" value="Area 1"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#2E7D32;strokeWidth=2;fillColor=#1b3d27;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="50" y="195" width="330" height="205" as="geometry"/>
    </mxCell>

    <!-- Area 0 (Backbone) — blue: encloses R2, R3, link L2 -->
    <mxCell id="area0_shape" value="Area 0&#10;(Backbone)"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#1565C0;strokeWidth=2;fillColor=#1a3a5c;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="235" y="165" width="380" height="235" as="geometry"/>
    </mxCell>

    <!-- Area 2 (Normal) — green: encloses R3, R4, link L3 -->
    <mxCell id="area2_shape" value="Area 2"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#2E7D32;strokeWidth=2;fillColor=#1b3d27;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="455" y="195" width="335" height="205" as="geometry"/>
    </mxCell>

    <!-- Area 3 (Normal) — green: encloses R3, R5, link L4 -->
    <mxCell id="area3_shape" value="Area 3"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#2E7D32;strokeWidth=2;fillColor=#1b3d27;opacity=35;fontSize=12;fontStyle=1;verticalAlign=bottom;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="455" y="345" width="190" height="215" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- ROUTER ICONS                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- R1 — Area 1 internal router; all neighbors to the right → label LEFT -->
    <mxCell id="R1" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R1&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;Area 1 Internal&lt;br&gt;Lo0: 10.0.0.1/32&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="90" y="265" width="60" height="60" as="geometry"/>
    </mxCell>

    <!-- R2 — ABR (Areas 0, 1); neighbors on both sides → label LEFT (fallback) -->
    <mxCell id="R2" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R2&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;ABR (Area 0/1)&lt;br&gt;Lo0: 10.0.0.2/32&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="300" y="265" width="60" height="60" as="geometry"/>
    </mxCell>

    <!-- R3 — Triple ABR (Areas 0, 2, 3); neighbors left+right+below → label above via bottom placement -->
    <mxCell id="R3" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R3&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;ABR (Area 0/2/3)&lt;br&gt;Lo0: 10.0.0.3/32&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=top;verticalAlign=bottom;align=center;labelPosition=center;"
      vertex="1" parent="1">
      <mxGeometry x="520" y="265" width="60" height="60" as="geometry"/>
    </mxCell>

    <!-- R4 — Area 2 internal router; all neighbors to the left → label RIGHT -->
    <mxCell id="R4" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R4&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;Area 2 Internal&lt;br&gt;Lo0: 10.0.0.4/32&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=left;labelPosition=right;"
      vertex="1" parent="1">
      <mxGeometry x="730" y="265" width="60" height="60" as="geometry"/>
    </mxCell>

    <!-- R5 — Area 3 internal router; only neighbor is above → label BELOW -->
    <mxCell id="R5" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R5&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;Area 3 Internal&lt;br&gt;Lo0: 10.0.0.5/32&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=bottom;verticalAlign=top;align=center;labelPosition=center;"
      vertex="1" parent="1">
      <mxGeometry x="520" y="440" width="60" height="60" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- CONNECTION LINES (white)                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- L1: R1 Gi0/0 ↔ R2 Gi0/0, 10.1.12.0/24, Area 1 -->
    <mxCell id="link_L1" value="Gi0/0 — Gi0/0&#10;10.1.12.0/24&#10;Area 1"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;align=center;fontColor=#FFFFFF;fontSize=10;"
      edge="1" parent="1" source="R1" target="R2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- L2: R2 Gi0/1 ↔ R3 Gi0/0, 10.1.23.0/24, Area 0 (backbone) -->
    <mxCell id="link_L2" value="Gi0/1 — Gi0/0&#10;10.1.23.0/24&#10;Area 0 (Backbone)"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;align=center;fontColor=#FFFFFF;fontSize=10;"
      edge="1" parent="1" source="R2" target="R3">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- L3: R3 Gi0/1 ↔ R4 Gi0/0, 10.1.34.0/24, Area 2 -->
    <mxCell id="link_L3" value="Gi0/1 — Gi0/0&#10;10.1.34.0/24&#10;Area 2"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;align=center;fontColor=#FFFFFF;fontSize=10;"
      edge="1" parent="1" source="R3" target="R4">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- L4: R3 Gi0/2 ↔ R5 Gi0/0, 10.1.35.0/24, Area 3 -->
    <mxCell id="link_L4" value="Gi0/2 — Gi0/0&#10;10.1.35.0/24&#10;Area 3"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;align=center;fontColor=#FFFFFF;fontSize=10;"
      edge="1" parent="1" source="R3" target="R5">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- IP LAST-OCTET LABELS                                        -->
    <!-- R1=10.1.12.1, R2 side of L1=10.1.12.2                     -->
    <!-- R2 side of L2=10.1.23.1, R3 side of L2=10.1.23.2          -->
    <!-- R3 side of L3=10.1.34.1, R4 side of L3=10.1.34.2          -->
    <!-- R3 side of L4=10.1.35.1, R5 side of L4=10.1.35.2          -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- L1 octets -->
    <mxCell id="L1_R1_octet" value=".1"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="168" y="270" as="geometry"/>
    </mxCell>

    <mxCell id="L1_R2_octet" value=".2"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="285" y="270" as="geometry"/>
    </mxCell>

    <!-- L2 octets -->
    <mxCell id="L2_R2_octet" value=".1"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="378" y="270" as="geometry"/>
    </mxCell>

    <mxCell id="L2_R3_octet" value=".2"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="505" y="270" as="geometry"/>
    </mxCell>

    <!-- L3 octets -->
    <mxCell id="L3_R3_octet" value=".1"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="600" y="270" as="geometry"/>
    </mxCell>

    <mxCell id="L3_R4_octet" value=".2"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="715" y="270" as="geometry"/>
    </mxCell>

    <!-- L4 octets -->
    <mxCell id="L4_R3_octet" value=".1"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="535" y="348" as="geometry"/>
    </mxCell>

    <mxCell id="L4_R5_octet" value=".2"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFFFF;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="535" y="432" as="geometry"/>
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- LEGEND BOX                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;&lt;br&gt;━━━  Physical Link&lt;br&gt;&lt;br&gt;[blue dashed] Area 0 (Backbone)&lt;br&gt;[green dashed] Area 1 (Normal)&lt;br&gt;[green dashed] Area 2 (Normal)&lt;br&gt;[green dashed] Area 3 (Normal)&lt;br&gt;&lt;br&gt;OSPF Process ID: 1&lt;br&gt;ABR = Area Border Router"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;arcSize=3;"
      vertex="1" parent="1">
      <mxGeometry x="660" y="470" width="200" height="150" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
