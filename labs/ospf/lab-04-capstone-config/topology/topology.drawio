<mxGraphModel background="#1a1a2e">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ═══════════════════════════════════════════════════════
         TITLE
    ════════════════════════════════════════════════════════ -->
    <mxCell id="title" value="&lt;font style=&quot;font-size:16px;&quot; color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Lab 04 — OSPF Full Protocol Mastery — Capstone I&lt;/b&gt;&lt;/font&gt;"
      style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="100" y="20" width="850" height="35" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         ZONE OVERLAYS — must appear before all routers/links
    ════════════════════════════════════════════════════════ -->

    <!-- Area 1 (Normal) — green; encloses R1 and the R1↔R2 link -->
    <mxCell id="area1_shape" value="Area 1&#10;(Normal)"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#2E7D32;strokeWidth=2;fillColor=#1b3d27;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="50" y="130" width="370" height="200" as="geometry" />
    </mxCell>

    <!-- Area 0 (Backbone) — blue; encloses R2 + L2 link + R3 -->
    <mxCell id="area0_shape" value="Area 0&#10;(Backbone)"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#1565C0;strokeWidth=2;fillColor=#1a3a5c;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="290" y="130" width="400" height="200" as="geometry" />
    </mxCell>

    <!-- Area 2 (Totally Stubby) — orange; encloses R3 (shared with Area 0) + L3 + R4 -->
    <mxCell id="area2_shape" value="Area 2&#10;(Totally Stubby)"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#E65100;strokeWidth=2;fillColor=#4a1e00;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="570" y="250" width="320" height="260" as="geometry" />
    </mxCell>

    <!-- Area 3 (NSSA) — purple; encloses R3 (shared) + L4 + R5 -->
    <mxCell id="area3_shape" value="Area 3&#10;(NSSA)"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#6A1B9A;strokeWidth=2;fillColor=#2e0d40;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="370" y="250" width="310" height="260" as="geometry" />
    </mxCell>

    <!-- External Zone — gray; encloses R6 + L5 -->
    <mxCell id="external_shape" value="External AS&#10;(No OSPF)"
      style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;dashed=1;strokeColor=#37474F;strokeWidth=2;fillColor=#1a2226;opacity=35;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#FFFFFF;spacingTop=6;"
      vertex="1" parent="1">
      <mxGeometry x="580" y="490" width="310" height="190" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         ROUTER ICONS
    ════════════════════════════════════════════════════════ -->

    <!-- R1: Area 1 internal — neighbors only to the right (R2); label goes LEFT -->
    <mxCell id="R1" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R1&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;Area 1 Internal&lt;br&gt;Lo0: 10.0.0.1/32&lt;br&gt;Lo1-3: 172.16.1-3.1/24&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="100" y="200" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R2: ABR Area 0/1 — neighbors on both sides (R1 left, R3 right); label BELOW -->
    <mxCell id="R2" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R2&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;ABR (Area 0/1)&lt;br&gt;Lo0: 10.0.0.2/32&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=bottom;verticalAlign=top;align=center;labelPosition=center;"
      vertex="1" parent="1">
      <mxGeometry x="360" y="200" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R3: Triple ABR + ASBR — neighbors on left (R2), below-left (R5), below-right (R4), below-far (R6); label RIGHT -->
    <mxCell id="R3" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R3&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;ABR+ASBR (Area 0/2/3)&lt;br&gt;Lo0: 10.0.0.3/32&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=left;labelPosition=right;"
      vertex="1" parent="1">
      <mxGeometry x="620" y="200" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R4: Area 2 internal — neighbor only above (R3); label RIGHT -->
    <mxCell id="R4" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R4&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;Area 2 Internal&lt;br&gt;(Totally Stubby)&lt;br&gt;Lo0: 10.0.0.4/32&lt;br&gt;Lo1: 172.16.4.1/24&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=left;labelPosition=right;"
      vertex="1" parent="1">
      <mxGeometry x="740" y="400" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R5: Area 3 NSSA ASBR — neighbor only above (R3); label LEFT -->
    <mxCell id="R5" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R5&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;Area 3 NSSA ASBR&lt;br&gt;Lo0: 10.0.0.5/32&lt;br&gt;Lo1: 172.16.5.1/24&lt;br&gt;Lo2: 192.168.55.1/24&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="460" y="400" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- R6: External AS (no OSPF) — neighbor only above (R3); label LEFT -->
    <mxCell id="R6" value="&lt;b style=&quot;color:#FFFFFF;&quot;&gt;R6&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px;&quot;&gt;External AS (no OSPF)&lt;br&gt;Lo0: 10.0.0.6/32&lt;br&gt;Lo1: 192.168.66.1/24&lt;/font&gt;"
      style="sketch=0;points=[[0.5,0,0],[1,0.5,0],[0.5,1,0],[0,0.5,0],[0.145,0.145,0],[0.8555,0.145,0],[0.855,0.8555,0],[0.145,0.855,0]];html=1;aspect=fixed;pointerEvents=1;shape=mxgraph.cisco19.rect;prIcon=router;fillColor=#FAFAFA;strokeColor=#005073;verticalLabelPosition=middle;verticalAlign=middle;align=right;labelPosition=left;"
      vertex="1" parent="1">
      <mxGeometry x="660" y="580" width="60" height="60" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         CONNECTION LINES
    ════════════════════════════════════════════════════════ -->

    <!-- L1: R1 Gi0/0 ↔ R2 Gi0/0, subnet 10.1.12.0/24, Area 1 -->
    <mxCell id="link_L1" value="Gi0/0 — Gi0/0&#10;10.1.12.0/24&#10;2001:db8:12::/64&#10;(Area 1)"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=10;fontColor=#CCCCCC;align=center;"
      edge="1" parent="1" source="R1" target="R2">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L2: R2 Gi0/1 ↔ R3 Gi0/0, subnet 10.1.23.0/24, Area 0 -->
    <mxCell id="link_L2" value="Gi0/1 — Gi0/0&#10;10.1.23.0/24&#10;2001:db8:23::/64&#10;(Area 0)"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=10;fontColor=#CCCCCC;align=center;"
      edge="1" parent="1" source="R2" target="R3">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L3: R3 Gi0/1 ↔ R4 Gi0/0, subnet 10.1.34.0/24, Area 2 -->
    <mxCell id="link_L3" value="Gi0/1 — Gi0/0&#10;10.1.34.0/24&#10;2001:db8:34::/64&#10;(Area 2)"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=10;fontColor=#CCCCCC;align=center;"
      edge="1" parent="1" source="R3" target="R4">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L4: R3 Gi0/2 ↔ R5 Gi0/0, subnet 10.1.35.0/24, Area 3 -->
    <mxCell id="link_L4" value="Gi0/2 — Gi0/0&#10;10.1.35.0/24&#10;2001:db8:35::/64&#10;(Area 3)"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;fontSize=10;fontColor=#CCCCCC;align=center;"
      edge="1" parent="1" source="R3" target="R5">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- L5: R3 Gi0/3 ↔ R6 Gi0/0, subnet 10.1.36.0/24, External — DASHED -->
    <mxCell id="link_L5" value="Gi0/3 — Gi0/0&#10;10.1.36.0/24&#10;2001:db8:36::/64&#10;(External)"
      style="endArrow=none;html=1;strokeWidth=2;strokeColor=#FFFFFF;fillColor=#f5f5f5;dashed=1;fontSize=10;fontColor=#CCCCCC;align=center;"
      edge="1" parent="1" source="R3" target="R6">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         IP LAST-OCTET LABELS
    ════════════════════════════════════════════════════════ -->

    <!-- L1: R1 side (.1) — R1 at x=100, y=200; interface exits right -->
    <mxCell id="L1_R1_octet" value=".1"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="185" y="218" as="geometry" />
    </mxCell>

    <!-- L1: R2 side (.2) — R2 at x=360, y=200; interface exits left -->
    <mxCell id="L1_R2_octet" value=".2"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="338" y="218" as="geometry" />
    </mxCell>

    <!-- L2: R2 side (.2) — R2 at x=360, y=200; interface exits right -->
    <mxCell id="L2_R2_octet" value=".2"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="445" y="218" as="geometry" />
    </mxCell>

    <!-- L2: R3 side (.3) — R3 at x=620, y=200; interface exits left -->
    <mxCell id="L2_R3_octet" value=".3"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="598" y="218" as="geometry" />
    </mxCell>

    <!-- L3: R3 side (.3) — R3 at x=620, y=200; interface exits bottom-right toward R4 -->
    <mxCell id="L3_R3_octet" value=".3"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="672" y="282" as="geometry" />
    </mxCell>

    <!-- L3: R4 side (.4) — R4 at x=740, y=400; interface exits top -->
    <mxCell id="L3_R4_octet" value=".4"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="730" y="378" as="geometry" />
    </mxCell>

    <!-- L4: R3 side (.3) — interface exits bottom-left toward R5 -->
    <mxCell id="L4_R3_octet" value=".3"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="600" y="282" as="geometry" />
    </mxCell>

    <!-- L4: R5 side (.5) — R5 at x=460, y=400; interface exits top -->
    <mxCell id="L4_R5_octet" value=".5"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="497" y="378" as="geometry" />
    </mxCell>

    <!-- L5: R3 side (.3) — interface exits bottom toward R6 (dashed) -->
    <mxCell id="L5_R3_octet" value=".3"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="638" y="290" as="geometry" />
    </mxCell>

    <!-- L5: R6 side (.6) — R6 at x=660, y=580; interface exits top -->
    <mxCell id="L5_R6_octet" value=".6"
      style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#FFFF99;"
      vertex="1" connectable="0" parent="1">
      <mxGeometry x="672" y="558" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         OSPF CONFIG ANNOTATIONS (capstone-specific)
         Yellow italic text cells near relevant routers
    ════════════════════════════════════════════════════════ -->

    <!-- R2 annotation: inter-area summary toward Area 1 -->
    <!-- R2 is at x=360, y=200; label is below the router icon -->
    <mxCell id="annot_R2_summary" value="&lt;i style=&quot;color:#FFD700;font-size:10px;&quot;&gt;area 1 range 172.16.0.0/21&lt;/i&gt;"
      style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="280" y="330" width="210" height="20" as="geometry" />
    </mxCell>

    <!-- R3 annotation 1: external summary (ASBR) — placed to the right of R3 label, above area boundary -->
    <!-- R3 is at x=620, y=200; label goes right. Place annotation below R3 label region -->
    <mxCell id="annot_R3_ext_summary" value="&lt;i style=&quot;color:#FFD700;font-size:10px;&quot;&gt;summary-address 192.168.0.0/16&lt;/i&gt;"
      style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="690" y="155" width="220" height="20" as="geometry" />
    </mxCell>

    <!-- R3 annotation 2: area 2 stub no-summary — near Area 2 zone (right side) -->
    <mxCell id="annot_R3_area2_stub" value="&lt;i style=&quot;color:#FFD700;font-size:10px;&quot;&gt;area 2 stub no-summary&lt;/i&gt;"
      style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="590" y="500" width="185" height="20" as="geometry" />
    </mxCell>

    <!-- R3 annotation 3: area 3 nssa — near Area 3 zone (left-center) -->
    <mxCell id="annot_R3_area3_nssa" value="&lt;i style=&quot;color:#FFD700;font-size:10px;&quot;&gt;area 3 nssa&lt;/i&gt;"
      style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="390" y="490" width="120" height="20" as="geometry" />
    </mxCell>

    <!-- R5 annotation: redistribute connected (NSSA ASBR) — below R5 label area -->
    <!-- R5 is at x=460, y=400; label goes left -->
    <mxCell id="annot_R5_redist" value="&lt;i style=&quot;color:#FFD700;font-size:10px;&quot;&gt;redistribute connected&lt;/i&gt;"
      style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="370" y="472" width="180" height="20" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════
         LEGEND BOX
    ════════════════════════════════════════════════════════ -->
    <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;&lt;br&gt;━━━  Physical Link (OSPF)&lt;br&gt;- - -  External Link (non-OSPF)&lt;br&gt;&lt;br&gt;[blue]   Area 0 — Backbone&lt;br&gt;[green]  Area 1 — Normal&lt;br&gt;[orange] Area 2 — Totally Stubby&lt;br&gt;[purple] Area 3 — NSSA&lt;br&gt;[gray]   External AS (no OSPF)&lt;br&gt;&lt;br&gt;OSPF Process ID: 1&lt;br&gt;R2 = ABR (Areas 0/1)&lt;br&gt;R3 = ABR (Areas 0/2/3) + ASBR&lt;br&gt;R5 = NSSA ASBR (Type-7 LSA)&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#FFD700;&quot;&gt;Yellow text = OSPF config commands&lt;/i&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;arcSize=3;"
      vertex="1" parent="1">
      <mxGeometry x="50" y="490" width="270" height="195" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
